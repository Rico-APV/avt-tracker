{
  "family": "avt-tracker",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::285806911028:role/avt-tracker-execution-role",
  "taskRoleArn": "arn:aws:iam::285806911028:role/avt-tracker-task-role",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "containerDefinitions": [
    {
      "name": "avt-tracker",
      "image": "285806911028.dkr.ecr.us-east-2.amazonaws.com/avt-tracker:placeholder",
      "essential": true,
      "portMappings": [
        {
          "name": "http",
          "containerPort": 3000,
          "protocol": "tcp"
        },
        {
          "name": "tracker-tcp",
          "containerPort": 6001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3000" },
        { "name": "DB_HOST", "value": "avt-tracker-db.cphj0ns5j3k3.us-east-2.rds.amazonaws.com" },
        { "name": "DB_PORT", "value": "5432" },
        { "name": "DB_DATABASE", "value": "avt_tracker" },
        { "name": "DB_SYNCHRONIZE", "value": "false" },
        { "name": "DB_LOGGING", "value": "false" },
        { "name": "DB_SSL", "value": "true" },
        { "name": "TRACKER_TCP_HOST", "value": "0.0.0.0" },
        { "name": "TRACKER_TCP_PORT", "value": "6001" },
        { "name": "TRACKER_TCP_SOCKET_TIMEOUT_MS", "value": "900000" },
        { "name": "TRACKER_TCP_MAX_BUFFER_BYTES", "value": "65536" },
        { "name": "AWS_REGION", "value": "us-east-2" },
        { "name": "SNS_TOPIC_ARN", "value": "arn:aws:sns:us-east-2:285806911028:avt-tracker-events" }
      ],
      "secrets": [
        {
          "name": "DB_USERNAME",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:285806911028:secret:avt-tracker/db-credentials:username::"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:285806911028:secret:avt-tracker/db-credentials:password::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/avt-tracker",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "avt-tracker",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
