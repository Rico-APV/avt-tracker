# HTTP API port (NestJS)
PORT=3000

# Postgres connection
# NOTE: host port 5433 (not the default 5432) on purpose - a native/local
# Postgres install on your machine may already be listening on 5432, and on
# Windows that can silently shadow Docker Desktop's localhost forwarding
# for that port. 5433 avoids the collision entirely.
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=avt
DB_PASSWORD=avt
DB_DATABASE=avt_tracker
DB_SYNCHRONIZE=false
DB_LOGGING=false
# Leave false for the local docker-compose Postgres (no SSL configured).
# Set to true for RDS or any Postgres that enforces SSL connections.
DB_SSL=false

# TCP listener for the AVT110 (and compatible AVT/ATL/ABT devices).
# Configure this same host/port on the device with:
#   AT@SIS=at,0,1,<your-server-ip>,<TRACKER_TCP_PORT>,,,0,0001#
TRACKER_TCP_PORT=6001
TRACKER_TCP_HOST=0.0.0.0

# Socket idle timeout in milliseconds. If a device stays silent longer than
# this (no +HBD, no +RPT), the connection is closed. 0 disables the timeout.
TRACKER_TCP_SOCKET_TIMEOUT_MS=900000

# Safety cap for the per-connection receive buffer. Frames are terminated by
# 0x23 ('#'); if no terminator shows up before this many bytes accumulate we
# assume the stream is garbage/desynced and drop the buffer.
TRACKER_TCP_MAX_BUFFER_BYTES=65536

# TCP listener for ERM/StarLink trackers (StarLink Tracker, TrackerSF, ...),
# on its own port, independent of the AVT110 listener above. 5136 is
# Traccar's documented default port for this protocol.
STARLINK_TCP_PORT=5136
STARLINK_TCP_HOST=0.0.0.0
STARLINK_TCP_SOCKET_TIMEOUT_MS=900000
# Safety cap for the per-connection receive buffer (this is a lightweight
# text-line protocol, so the default is much smaller than the AVT110 one).
STARLINK_TCP_MAX_BUFFER_BYTES=8192

# Publishes tracker.device.*/tracker.report.received domain events to this
# SNS topic so other services can consume them. Leave SNS_TOPIC_ARN empty to
# disable publishing entirely (e.g. local dev without an AWS account).
AWS_REGION=us-east-2
SNS_TOPIC_ARN=
